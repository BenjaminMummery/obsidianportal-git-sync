# API key used by ChatGPT Actions, scripts, and GitHub Actions to call this bridge.
LORE_BRIDGE_API_KEY=replace_with_a_long_random_secret

# Obsidian Portal OAuth 1.0a credentials.
OP_CONSUMER_KEY=replace_me
OP_CONSUMER_SECRET=replace_me
OP_ACCESS_TOKEN=replace_me
OP_ACCESS_TOKEN_SECRET=replace_me
OP_CAMPAIGN_ID=replace_me

# GitHub repository that stores the markdown lore mirror.
GITHUB_TOKEN=github_pat_or_fine_grained_token_with_contents_write
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=sindrel-lore
GITHUB_BRANCH=main
GITHUB_AUTHOR_NAME=Sindrel Lore Bridge
GITHUB_AUTHOR_EMAIL=lore-bridge@example.com

# Optional: if configured, /github/webhook verifies GitHub's x-hub-signature-256.
GITHUB_WEBHOOK_SECRET=

# Repo layout.
LORE_WIKI_DIR=lore/wiki
LORE_STATE_PATH=metadata/sync-state.json

# Safety switches.
ALLOW_CREATE_FROM_GIT=true
ALLOW_DELETE_FROM_GIT=false
CACHE_TTL_SECONDS=900
